<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
	<head>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="x-apple-disable-message-reformatting" />
		<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
		<meta name="color-scheme" content="light dark" />
		<meta name="supported-color-schemes" content="light dark" />
		<title></title>
		<style type="text/css" rel="stylesheet" media="all">
			@import url("https://fonts.googleapis.com/css?family=Nunito+Sans:400,700&display=swap");
			body {
				width: 100% !important;
				height: 100%;
				margin: 0;
				padding: 0;
				-webkit-text-size-adjust: none;
				font-family: "Nunito Sans", Helvetica, Arial, sans-serif;
				background-color: #f2f4f6;
				color: #51545e;
			}
			.email-wrapper {
				width: 100%;
				margin: 0;
				padding: 40px 0;
				background-color: #f2f4f6;
			}
			.email-content {
				width: 100%;
				max-width: 600px;
				margin: 0 auto;
				background-color: #ffffff;
				border-radius: 12px;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
				overflow: hidden;
			}
			.email-masthead {
				padding: 30px 40px 20px;
				text-align: center;
				background: linear-gradient(135deg, #ffffff 0%, #ffffff 100%);
			}
			.email-masthead_logo {
				max-width: 120px;
				height: auto;
			}
			.email-body {
				padding: 40px;
			}
			.email-body_inner {
				background-color: #ffffff;
			}
			.content-cell {
				padding: 0;
			}
			h1 {
				margin-top: 0;
				color: #333333;
				font-size: 24px;
				font-weight: bold;
				text-align: left;
			}
			p {
				margin: 16px 0;
				font-size: 16px;
				line-height: 1.6;
				color: #51545e;
			}
			.button {
				background-color: #007bff;
				border-top: 12px solid #007bff;
				border-right: 24px solid #007bff;
				border-bottom: 12px solid #007bff;
				border-left: 24px solid #007bff;
				display: inline-block;
				color: #ffffff !important;
				text-decoration: none;
				border-radius: 6px;
				box-shadow: 0 2px 8px rgba(0, 123, 255, 0.3);
				-webkit-text-size-adjust: none;
				box-sizing: border-box;
				font-weight: bold;
				font-size: 16px;
			}
			.body-action {
				width: 100%;
				margin: 30px auto;
				padding: 0;
				text-align: center;
			}
			.body-sub {
				margin-top: 30px;
				padding-top: 25px;
				border-top: 1px solid #eaeaec;
			}
			.email-footer {
				width: 100%;
				margin: 0 auto;
				padding: 30px 40px;
				text-align: center;
				background-color: #ffffff;
			}
			.email-footer p {
				color: #000000;
				font-size: 13px;
				margin: 8px 0;
			}
			.unlock-badge {
				display: inline-block;
				background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
				color: #ffffff;
				padding: 8px 20px;
				border-radius: 20px;
				font-size: 14px;
				font-weight: bold;
				margin: 16px 0;
			}
			.message-box {
				background-color: #ffffff;
				border-left: 4px solid #007bff;
				padding: 20px;
				margin: 24px 0;
				border-radius: 0 8px 8px 0;
			}
			.message-box p {
				margin: 0;
				color: #333333;
			}
			@media only screen and (max-width: 600px) {
				.email-content {
					width: 100% !important;
					border-radius: 0 !important;
				}
				.email-body {
					padding: 24px !important;
				}
				.email-masthead {
					padding: 24px 20px 16px !important;
				}
				.email-footer {
					padding: 24px 20px !important;
				}
				.button {
					width: 100% !important;
					text-align: center !important;
				}
			}
			@media (prefers-color-scheme: dark) {
				body,
				.email-wrapper,
				.email-content,
				.email-body,
				.email-body_inner,
				.email-footer {
					background-color: #1a1a2e !important;
					color: #e0e0e0 !important;
				}
				h1 {
					color: #ffffff !important;
				}
				p {
					color: #cccccc !important;
				}
				.message-box {
					background-color: #1e1e2e !important;
					border-left-color: #4dabf7 !important;
				}
				.message-box p {
					color: #e0e0e0 !important;
				}
				.email-footer {
					background-color: #1e1e2e !important;
					border-top-color: #333 !important;
				}
				.email-footer p {
					color: #888 !important;
				}
			}
		</style>
		<!--[if mso]>
			<style type="text/css">
				.f-fallback {
					font-family: Arial, sans-serif;
				}
			</style>
		<![endif]-->
	</head>
	<body>
		<table class="email-wrapper" width="100%" cellpadding="0" cellspacing="0" role="presentation">
			<tr>
				<td align="center">
					<table class="email-content" width="100%" cellpadding="0" cellspacing="0" role="presentation">
						<tr>
							<td class="email-masthead">
								<img 
									src="https://everycare.co.uk/wp-content/themes/everycareuk2017/library/images/ec-logo.png" 
									alt="Everycare Romford" 
									width="120" 
									style="max-width: 120px; height: auto; display: block; margin: 0 auto;" 
									class="email-masthead_logo"
								/>
							</td>
						</tr>
						<tr>
							<td class="email-body" width="100%" cellpadding="0" cellspacing="0">
								<table class="email-body_inner" align="center" width="570" cellpadding="0" cellspacing="0" role="presentation">
									<tr>
										<td class="content-cell">
											<div class="f-fallback">
												<h1>Hello <%= name %>,</h1>
												
												<div class="unlock-badge">
													<%= unlockType %>
												</div>
												
												<div class="message-box">
													<p><%= unlockMessage %></p>
												</div>
												
												<table class="body-action" align="center" width="100%" cellpadding="0" cellspacing="0" role="presentation">
													<tr>
														<td align="center">
															<table width="100%" border="0" cellspacing="0" cellpadding="0" role="presentation">
																<tr>
																	<td align="center">
																		<a 
																			href="<%= websiteUrl %>" 
																			class="f-fallback button" 
																			target="_blank"
																			style="color: #ffffff !important; text-decoration: none;"
																		>
																			Access Your Portal
																		</a>
																	</td>
																</tr>
															</table>
														</td>
													</tr>
												</table>
												
												<p>If you have any questions or need assistance, please don't hesitate to contact our support team.</p>
												
												<table class="body-sub" role="presentation">
													<tr>
														<td>
															<p class="f-fallback sub" style="font-size: 13px; color: #000000; margin: 0;">
																If you're having trouble with the button above, copy and paste the URL below into your web browser.
															</p>
															<p class="f-fallback sub" style="font-size: 13px; color: #007bff; word-break: break-all; margin: 8px 0 0;"><%= websiteUrl %></p>
														</td>
													</tr>
												</table>
											</div>
										</td>
									</tr>
								</table>
							</td>
						</tr>
						<tr>
							<td>
								<table class="email-footer" align="center" width="570" cellpadding="0" cellspacing="0" role="presentation">
									<tr>
										<td class="content-cell " align="center" style="color: #000000;">
											<p class="f-fallback sub align-center" style="margin: 0;">
												Everycare Romford<br />
												Visit us at <a href="career.everycareromford.co.uk" style="color: #007bff;">career.everycareromford.co.uk</a>
											</p>
											<p class="f-fallback sub align-center" style="font-size: 12px; color: #3a3a3a; margin: 16px 0 0;">
												Please don't reply to this email. This mailbox is not monitored.
											</p>
										</td>
									</tr>
								</table>
							</td>
						</tr>
					</table>
				</td>
			</tr>
		</table>
	</body>
</html>